# ── Database ──────────────────────────────────────
# For SQLite (default dev):
DATABASE_URL=sqlite+aiosqlite:///./football_analysis.db
# For PostgreSQL (production):
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/football_analysis

# ── File Storage ──────────────────────────────────
UPLOAD_DIR=./uploads
COMMENTARY_DIR=./commentary_videos

# ── OpenAI ────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# ── HuggingFace Model Repos ──────────────────────
HF_XG_REPO=your-org/xg-model
HF_VAEP_SCORING_REPO=your-org/vaep-scoring-model
HF_VAEP_CONCEDING_REPO=your-org/vaep-conceding-model
HF_STYLE_SCALER_REPO=your-org/style-scaler
HF_STYLE_AUTOENCODER_REPO=your-org/style-autoencoder
HF_STYLE_KMEANS_REPO=your-org/style-kmeans
HF_CACHE_DIR=./model_cache

# ── GPU / Deployment ─────────────────────────────
# GPU_PROVIDER=         # 'vastai', 'runpod', or leave empty for local
# VASTAI_API_KEY=
# RUNPOD_API_KEY=
FORCE_CPU=false

# ── CORS ──────────────────────────────────────────
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
