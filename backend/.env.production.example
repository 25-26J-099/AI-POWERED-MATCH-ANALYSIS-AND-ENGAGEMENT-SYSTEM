# ============================================================================
# Production environment variables — GCP Compute Engine deployment
# Copy this file to .env on the VM and fill in the real values.
# Secrets are fetched from GCP Secret Manager by vm-startup.sh automatically.
# ============================================================================

# ── Database (Cloud SQL via Unix socket through Cloud SQL Auth Proxy) ─────────
DATABASE_URL=postgresql+asyncpg://appuser:YOUR_DB_PASSWORD@/football_analysis?host=/cloudsql/PROJECT_ID:us-central1:football-ai-db

# ── Cloud Storage ─────────────────────────────────────────────────────────────
GCS_BUCKET=football-ai-495521

# ── HuggingFace ───────────────────────────────────────────────────────────────
HF_FOOTBALL_MODELS_REPO=AI-POWERED-FOOTBALL-SYSTEM/football-ai-models
HF_XG_REPO=AI-POWERED-FOOTBALL-SYSTEM/football-ai-models
HF_VAEP_SCORING_REPO=AI-POWERED-FOOTBALL-SYSTEM/football-ai-models
HF_VAEP_CONCEDING_REPO=AI-POWERED-FOOTBALL-SYSTEM/football-ai-models
HF_STYLE_SCALER_REPO=AI-POWERED-FOOTBALL-SYSTEM/football-ai-models
HF_STYLE_AUTOENCODER_REPO=AI-POWERED-FOOTBALL-SYSTEM/football-ai-models
HF_STYLE_KMEANS_REPO=AI-POWERED-FOOTBALL-SYSTEM/football-ai-models
HF_TOKEN=hf_xxxxxxxxxxxx   # only needed if the repo is private
HF_CACHE_DIR=/data/model_cache

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxx
OPENAI_MODEL=gpt-4o

# ── MLflow ────────────────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=http://mlflow:5000

# ── Prefect ───────────────────────────────────────────────────────────────────
PREFECT_API_URL=https://api.prefect.cloud/api/accounts/ACCOUNT_ID/workspaces/WORKSPACE_ID
PREFECT_API_KEY=pnu_xxxxxxxxxxxx

# ── Storage paths (containerised — match docker-compose.yml volumes) ──────────
UPLOAD_DIR=/data/uploads
COMMENTARY_DIR=/data/commentary_videos

# ── GPU / device ──────────────────────────────────────────────────────────────
FORCE_CPU=false
GNN_DEVICE=cuda
FASTREID_ENABLED=true
FASTREID_DEVICE=auto
TORCHREID_DEVICE=cuda
TORCHREID_ALLOW_CPU=false
OCR_USE_GPU=true

# ── Binary paths (already on PATH in the Docker container) ───────────────────
FFMPEG_BINARY=ffmpeg
SOX_BINARY=sox
OLLAMA_BINARY=ollama
OLLAMA_URL=http://ollama:11434

# ── Re-ID ────────────────────────────────────────────────────────────────────
REID_BACKEND_PRIORITY=fastreid,torchreid,handcrafted
FASTREID_CONFIG_PATH=./models/reid/fastreid/configs/football_vit.yml
FASTREID_WEIGHTS_PATH=./models/reid/fastreid/weights/football_vit.pth

# ── CORS (update with your Cloud Run frontend URL) ────────────────────────────
CORS_ORIGINS=["https://YOUR_CLOUD_RUN_URL.run.app","http://localhost","http://localhost:3000"]

# ── Commentary defaults ────────────────────────────────────────────────────────
COMMENTARY_LEVEL=Intermediate
COMMENTARY_VERBOSITY=medium
COMMENTARY_EDUCATIONAL_MODE=false
COMMENTARY_STYLE=neutral

# ── Security ──────────────────────────────────────────────────────────────────
ENTERPRISE_ENFORCE_API_KEY=false
SECURITY_ENABLE_HEADERS=true
RATE_LIMIT_REQUESTS=120
RATE_LIMIT_WINDOW_SECONDS=60
